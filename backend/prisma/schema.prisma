generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

type Rarity = "common" | "rare" | "elite" | "mythic" | "ascendant"

enum RoomType {
  guard
  vault
  ritual
  trap
  boss
}

enum MoodState {
  steadfast
  inspired
  tense
  broken
}

model Player {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  createdAt DateTime @default(now())
  heroes    Hero[]
  towers    Tower[]
}

model Hero {
  id             String   @id
  name           String
  title          String
  rarity         Rarity
  archetype      String
  specialization String
  level          Int
  xp             Int
  hp             Int
  atk            Int
  def            Int
  mag            Int
  spd            Int
  traits         String
  backstory      String
  portrait       String
  moodState      MoodState
  morale         Int
  loyalty        Int
  fear           Int
  player         Player   @relation(fields: [playerId], references: [id])
  playerId       String
}

model Tower {
  id        String   @id
  name      String
  theme     String
  width     Int
  height    Int
  dpBudget  Int
  usedDp    Int
  cells     Json
  defenders String[]
  player    Player   @relation(fields: [playerId], references: [id])
  playerId  String
}

model CombatLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  battle    String
  log       Json
}
